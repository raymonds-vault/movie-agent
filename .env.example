# ── Ollama Configuration ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_CODE_MODEL=deepseek-coder

# ── OMDb Configuration ───────────────────────────────
OMDB_API_KEY=your_omdb_api_key_here

# ── Application ──────────────────────────────────────
APP_NAME=Movie Agent
DEBUG=true
LOG_LEVEL=INFO
# Start Vite in frontend/ when API starts; open REACT_DEV_URL in browser
AUTO_START_REACT_DEV=true
OPEN_REACT_BROWSER=true
REACT_DEV_URL=http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/movie_agent

# ── Langfuse (optional — run: docker compose up -d) ───
# UI: http://localhost:3001 (docker compose default; LANGFUSE_WEB_PORT). Sign up, create project "movie-agent", paste **this stack’s** API keys (keys from an old Langfuse v2 UI will 401).
# https://langfuse.com/docs — never commit real keys.
# Tracing runs when both keys are set; set LANGFUSE_ENABLED=false to turn off.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PROJECT_NAME=movie-agent
