# ── OpenAI (LangGraph + Pinecone embeddings) ───────────
# When set, the agent uses OpenAI chat; Redis semantic cache still uses Ollama embeddings below.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Comma-separated: cheap → expensive (synthesis escalates on low quality until good-enough or max passes)
OPENAI_CHAT_MODEL_TIERS=gpt-4o-mini,gpt-4o
OPENAI_CHAT_MODEL_CONTEXT=
OPENAI_CHAT_MODEL_TOOLS=
OPENAI_CHAT_MODEL_QUALITY=

# ── Pinecone (optional movie RAG) ──────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=movies
PINECONE_RETRIEVAL_TOP_K=8
PINECONE_MIN_SCORE=0.35
PINECONE_MAX_UNIQUE_MOVIES=5
PINECONE_CONTEXT_MAX_CHARS=4000
MOVIE_EMBED_MAX_OVERVIEW_CHARS=1500
MOVIE_MAX_CHUNKS_PER_MOVIE=1

# ── Ollama (Redis embeddings + LLM fallback if no OpenAI) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_CODE_MODEL=deepseek-coder
# Per-step model routing when OpenAI is not configured
OLLAMA_CONTEXT_MODEL=
OLLAMA_TOOL_DECISION_MODEL=
OLLAMA_SYNTH_MODEL=
OLLAMA_QUALITY_MODEL=
OLLAMA_SYNTH_FALLBACK_MODEL=
# Quality 1–10 — ship when score >= QUALITY_MIN_SCORE; stop escalating at >= QUALITY_GOOD_ENOUGH
QUALITY_MIN_SCORE=6
QUALITY_GOOD_ENOUGH=8
MAX_SYNTHESIS_PASSES=2
# Summarize only when history has at least this many messages
HISTORY_SUMMARY_MIN_MESSAGES=8
# Rule-based minimum response size before conditional quality LLM
QUALITY_RULE_MIN_CHARS=40

# ── OMDb Configuration ───────────────────────────────
OMDB_API_KEY=your_omdb_api_key_here

# ── Firebase Auth (backend verifies ID tokens) ────────
# Set AUTH_DEV_BYPASS=true for local/tests without Firebase (never in production).
AUTH_ENABLED=true
AUTH_DEV_BYPASS=false
FIREBASE_PROJECT_ID=
# Service account JSON path from Firebase Console (Project settings → Service accounts)
FIREBASE_CREDENTIALS_PATH=
# Or paste the entire JSON as a single line (alternative to FIREBASE_CREDENTIALS_PATH)
FIREBASE_CREDENTIALS_JSON=

# ── Application ──────────────────────────────────────
APP_NAME=Movie Agent
DEBUG=true
LOG_LEVEL=INFO
# Start Vite in frontend/ when API starts; open REACT_DEV_URL in browser
AUTO_START_REACT_DEV=true
OPEN_REACT_BROWSER=true
REACT_DEV_URL=http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/movie_agent

# ── Langfuse (optional — run: docker compose up -d) ───
# UI: http://localhost:3001 (docker compose default; LANGFUSE_WEB_PORT). Sign up, create project "movie-agent", paste **this stack’s** API keys (keys from an old Langfuse v2 UI will 401).
# https://langfuse.com/docs — never commit real keys.
# Tracing runs when both keys are set; set LANGFUSE_ENABLED=false to turn off.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PROJECT_NAME=movie-agent
