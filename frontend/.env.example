# Dev proxy target for FastAPI (HTTP + WebSocket under /api)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Langfuse UI base URL — match LANGFUSE_HOST (docker compose default: http://localhost:3001)
VITE_LANGFUSE_HOST=http://localhost:3001

# ── Firebase (Web client) — from Firebase Console → Project settings → Your apps
# When backend uses AUTH_DEV_BYPASS=true, set VITE_AUTH_DEV_BYPASS=true to skip login UI.
VITE_AUTH_DEV_BYPASS=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics in the browser
VITE_FIREBASE_MEASUREMENT_ID=
